# LLM Provider — groq, deepseek, or openrouter
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# For DeepSeek (alternative):
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-your-deepseek-key

# For OpenRouter (alternative):
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-your-openrouter-key

# Database (SQLite for local dev)
DATABASE_URL=sqlite:///./data/documents.db

# Processing
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE_MB=20

# Confidence thresholds
CONFIDENCE_THRESHOLD_AUTO=0.8
CONFIDENCE_THRESHOLD_MCQ=0.5

# Learning
MIN_CORRECTIONS_FOR_RETRAIN=100

SECRET_KEY=local-dev-key-change-in-prod
DEBUG=true
